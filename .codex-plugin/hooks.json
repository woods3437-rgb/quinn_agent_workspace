{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "${CODEX_PLUGIN_ROOT}/hooks/mempal-hook.sh session-start"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "${CODEX_PLUGIN_ROOT}/hooks/mempal-hook.sh stop"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "${CODEX_PLUGIN_ROOT}/hooks/mempal-hook.sh precompact"
          }
        ]
      }
    ]
  }
}
